# RawClaw Port Unification
# Ref: Blocker 4 (URL cleanup)

# API Gateway (NestJS)
API_PORT=3000
API_URL="http://localhost:3000"
DATABASE_URL="file:./apps/api/prisma/dev.db"

# Agent Subsystem (FastAPI)
AGENT_PORT=8000
AGENT_URL="http://localhost:8000"

# Sandbox Configuration (Blocker 3)
SANDBOX_DOCKER_IMAGE="python:3.11-slim"
SANDBOX_WORKSPACE_DIR="/tmp/rawclaw-sandbox"

# Vector Store (ChromaDB)
CHROMA_SERVER_HOST="localhost"
CHROMA_SERVER_HTTP_PORT=8000

# Cache / Queue
REDIS_URL="redis://localhost:6379"

# Search & Fetch
BRAVE_API_KEY=""

# Security
JWT_SECRET="PLEASE_CHANGE_ME_TO_A_LONG_RANDOM_STRING"
AUTH_SECRET="A_STRONG_SECRET_FOR_BOOTSTRAP"
ALLOW_LOCAL_AUTH="true"
ENCRYPTION_KEY="32-CHAR-HEX-KEY-FOR-VAULT"

# LLM Providers (Ollama-Only Mode)
OLLAMA_BASE_URL="http://localhost:11434"
# Example IDs for routing:
# DEFAULT_LOW_MODEL="ollama/qwen2.5:1.5b"
# DEFAULT_MEDIUM_MODEL="ollama/llama3.2:3b"
# DEFAULT_HIGH_MODEL="ollama/llama3:8b"
# Support for cloud-backed models:
# DEFAULT_CLOUD_MODEL="ollama/qwen3-coder:480b-cloud"
DOCKER_MCP_TRANSPORT="stdio"
DOCKER_MCP_PROFILE=""
DOCKER_MCP_URL="http://localhost:8811"
# Turborepo (disable git hashing on Windows)
TURBO_FORCE_GIT=0
