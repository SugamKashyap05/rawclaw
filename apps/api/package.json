{
  "name": "@rawclaw/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma db push && ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "prisma generate && tsc",
    "lint": "echo 'Linting (ESLint) deferred to Phase 3'",
    "test": "echo 'Unit tests (Jest) deferred to Phase 3'",
    "check-types": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.4.22",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@rawclaw/shared": "^0.1.0",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.6.1",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "prisma": "^7.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
