// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Session {
  id               String    @id @default(cuid())
  title            String?
  workspaceId      String    @default("default")
  senderIdentifier String    @default("local")
  surfaceType      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  messages         Message[]

  @@index([workspaceId])
  @@map("sessions")
}

model ToolConfirmation {
  id          String    @id @default(cuid())
  sessionId   String
  toolName    String
  toolInput   String    // JSON stringified input
  status      String    @default("pending") // pending | approved | denied
  requestedAt DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([sessionId])
  @@map("tool_confirmations")
}

model Message {
  id        String   @id @default(cuid())
  role      String
  content   String
  toolCalls String?  // Store as JSON string
  toolResults String? // Store as JSON string
  provenance String?  // Store as JSON string
  citations String?  // Store as JSON string
  
  // P1 Metadata
  modelId      String?
  isLocal      Boolean?
  fallbacks    String?  // JSON string array
  memoryRecall Boolean?
  agentId      String?
  errorType    String?
  errorMessage String?
  attachments  String? // JSON stringified ChatAttachment[]
  durationMs   Int?

  createdAt DateTime @default(now())
  
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model TaskDefinition {
  id          String    @id @default(cuid())
  name        String
  description String
  agentId     String?
  toolIds     String    // JSON array of tool names
  schedule    String?   // cron expression or null
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  runs        TaskRun[]

  @@map("task_definitions")
}

model TaskRun {
  id              String          @id @default(cuid())
  definitionId    String
  definition      TaskDefinition  @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  status          String          @default("queued")
  startedAt       DateTime?
  finishedAt      DateTime?
  selectedAgent   String?
  outputPath      String?
  provenance      String?         // JSON stringified ProvenanceTrace
  errorMessage    String?
  createdAt       DateTime        @default(now())
  steps           RunStep[]

  @@map("task_runs")
}

model RunStep {
  id          String   @id @default(cuid())
  runId       String
  run         TaskRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepIndex   Int
  stepType    String   // plan | tool_call | tool_result | synthesis | error
  toolName    String?
  inputSummary  String?
  outputSummary String?
  sourceUrl   String?
  durationMs  Int?
  sandboxed   Boolean  @default(false)
  timestamp   DateTime @default(now())

  @@map("run_steps")
}

model ModelPreference {
  id          String   @id @default(cuid())
  modelId     String   @unique
  customName  String?
  isFavorite  Boolean  @default(false)
  provider    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("model_preferences")
}

model AgentProfile {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  systemPrompt String
  status       String   @default("idle")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("agent_profiles")
}

model McpServerConfig {
  id         String   @id @default(cuid())
  name       String   @unique
  type       String
  command    String
  args       String?  // JSON string array
  env        String?  // JSON object
  status     String   @default("stopped")
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("mcp_server_configs")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model MemoryEntry {
  id         String   @id @default(cuid())
  content    String
  tags       String?  // JSON string array
  source     String?
  collection String   @default("default")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([collection])
  @@map("memory_entries")
}

model Document {
  id            String   @id @default(cuid())
  filename      String
  mimeType      String
  extractedText String
  extractionMethod String @default("unknown")
  metadata      String?  // JSON stringified
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("documents")
}
