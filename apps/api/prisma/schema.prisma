// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Session {
  id               String    @id @default(cuid())
  title            String?
  workspaceId      String    @default("default")
  senderIdentifier String    @default("local")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  messages         Message[]

  @@index([workspaceId])
  @@map("sessions")
}

model ToolConfirmation {
  id          String    @id @default(cuid())
  sessionId   String
  toolName    String
  toolInput   String    // JSON stringified input
  status      String    @default("pending") // pending | approved | denied
  requestedAt DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([sessionId])
  @@map("tool_confirmations")
}

model Message {
  id        String   @id @default(cuid())
  role      String
  content   String
  toolCalls String?  // Store as JSON string
  citations String?  // Store as JSON string
  createdAt DateTime @default(now())
  
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model TaskDefinition {
  id          String    @id @default(cuid())
  name        String
  description String
  agentId     String?
  toolIds     String    // JSON array of tool names
  schedule    String?   // cron expression or null
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  runs        TaskRun[]

  @@map("task_definitions")
}

model TaskRun {
  id              String          @id @default(cuid())
  definitionId    String
  definition      TaskDefinition  @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  status          String          @default("queued")
  startedAt       DateTime?
  finishedAt      DateTime?
  selectedAgent   String?
  outputPath      String?
  provenance      String?         // JSON stringified ProvenanceTrace
  errorMessage    String?
  createdAt       DateTime        @default(now())
  steps           RunStep[]

  @@map("task_runs")
}

model RunStep {
  id          String   @id @default(cuid())
  runId       String
  run         TaskRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepIndex   Int
  stepType    String   // plan | tool_call | tool_result | synthesis | error
  toolName    String?
  inputSummary  String?
  outputSummary String?
  sourceUrl   String?
  durationMs  Int?
  sandboxed   Boolean  @default(false)
  timestamp   DateTime @default(now())

  @@map("run_steps")
}
